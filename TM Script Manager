  /* ============================ small helpers ============================ */
  function addStyle(css) {
    const s = document.createElement('style');
    s.textContent = css;
    (document.head || document.documentElement).appendChild(s);
  }
  function el(tag, cls, text) {
    const e = document.createElement(tag);
    if (cls) e.className = cls;
    if (text != null) e.textContent = text;
    return e;
  }
  function onReady(fn) {
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', fn, { once: true });
    else fn();
  }

  // Navigate straight to the new site's category page for a model.
  // Pattern (confirmed): "S26 Ultra (S948)" -> /products/s26-ultra-(s948)
  // i.e. model name, lowercased, spaces -> dashes (parentheses kept).
  function goToCategory(term) {
    const slug = (term || '').trim().toLowerCase().replace(/\s+/g, '-');
    if (!slug) return;
    // leave a short-lived breadcrumb so the next page knows which filter to auto-apply
    try {
      sessionStorage.setItem('cpxAutoFilter', JSON.stringify({ t: Date.now(), f: getFilterPref() }));
    } catch (e) {}
    location.href = 'https://www.crazyparts.com.au/products/' + slug;
  }

  // On a category page reached via the menu, auto-apply the chosen filter
  // (Repair Parts or Accessories) once the Category panel renders — but only if that
  // option exists and isn't already applied. The breadcrumb is consumed on use and
  // ignored after 15s, so it never hijacks normal browsing.
  function maybeAutoFilter() {
    if (!AUTO_FILTER) return;
    if (!/^\/products\//.test(location.pathname)) return;
    let info = null;
    try { info = JSON.parse(sessionStorage.getItem('cpxAutoFilter') || 'null'); } catch (e) {}
    if (!info || !info.t || Date.now() - info.t > 15000) return;

    const want = info.f === 'accessories' ? 'accessories' : 'repair';
    const rx = want === 'accessories' ? /^accessories\b/i : /^repair parts\b/i;

    // the Category filter options are the only links that point back to this page
    // with a ?type=NNNN query — match the one whose label we want.
    const link = [...document.querySelectorAll('a[href*="type="]')]
      .find((a) => rx.test(a.textContent.replace(/\s+/g, ' ').trim()));
    if (!link) return; // Category panel not rendered yet — try again on next mutation

    const m = (link.getAttribute('href') || '').match(/type=(\d+)/);
    const cur = new URLSearchParams(location.search).get('type');
    try { sessionStorage.removeItem('cpxAutoFilter'); } catch (e) {} // consume: only once
    if (m && cur === m[1]) return; // already on that filter — nothing to do
    link.click();
  }

  // Force the product listing to show PAGE_SIZE items per page instead of the site's
  // default (36). The site uses an Ant Design pagination "size changer" that reads like
  // "36 / page"; this opens it and picks PAGE_SIZE (or the largest option available if
  // PAGE_SIZE isn't offered). Runs at most once per listing page/query.
  let cpxSizeHandled = '';
  function maybePageSize() {
    if (!PAGE_SIZE) return;
    if (!/^\/products\//.test(location.pathname)) return;
    const key = location.pathname + location.search;
    if (cpxSizeHandled === key) return;

    const sizer = document.querySelector('.ant-pagination-options .ant-select-selector');
    if (!sizer) return;                                   // pagination not rendered yet
    const cur = (sizer.textContent.match(/(\d+)\s*\/\s*page/) || [])[1];
    if (cur && parseInt(cur, 10) >= PAGE_SIZE) { cpxSizeHandled = key; return; }

    cpxSizeHandled = key;                                  // claim this page (don't reopen)
    sizer.dispatchEvent(new MouseEvent('mousedown', { bubbles: true, cancelable: true, view: window }));
    setTimeout(() => {
      const opts = [...document.querySelectorAll('.ant-select-item-option')];
      const exact = opts.find((o) => new RegExp('^\\s*' + PAGE_SIZE + '\\b').test(o.textContent.trim()));
      const biggest = opts.filter((o) => /^\d+\b/.test(o.textContent.trim()))
                          .sort((a, b) => parseInt(b.textContent, 10) - parseInt(a.textContent, 10))[0];
      const pick = exact || biggest;
      if (pick) pick.click();
