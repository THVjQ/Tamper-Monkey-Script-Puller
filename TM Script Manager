  // Runtime list = base entries + anything found by the GitHub scan.
  // Reassigned in main() and after a scan; closures read it by name.
  let SCRIPTS = BASE_SCRIPTS.slice();

  const CATEGORIES  = ['CrazyParts', 'SOSPOS', 'Other'];
  const CAT_ICONS   = { CrazyParts: '🔧', SOSPOS: '📱', Other: '🌐' };

  // ── Helpers ───────────────────────────────────────────────────────────────

  function isNew(script) {
    if (!script.addedDate) return false;
    return Date.now() - new Date(script.addedDate).getTime() < NEW_DAYS * 86400000;
  }

  function repoFromUrl(url) {
    // url = `${GH}/<repo>/<branch>/<path...>`
    return url.replace(GH + '/', '').split('/')[0];
  }

  function guessCategory(text) {
    if (/crazyparts/i.test(text)) return 'CrazyParts';
    if (/sospos/i.test(text))     return 'SOSPOS';
    return 'Other';
  }

  function parseMeta(src) {
    const meta = { name: null, match: [] };
    const block = src.match(/\/\/ ==UserScript==([\s\S]*?)\/\/ ==\/UserScript==/);
    if (!block) return meta;
    block[1].split('\n').forEach(line => {
      const m = line.match(/^\s*\/\/\s*@(\w+)\s+(.+?)\s*$/);
      if (!m) return;
      if (m[1] === 'name' && !meta.name) meta.name = m[2];
      else if (m[1] === 'match' || m[1] === 'include') meta.match.push(m[2]);
    });
    return meta;
  }

  function matchPattern(pattern, url) {
    try {
      const u   = new URL(url);
      const sep = pattern.indexOf('://');
      if (sep === -1) return false;
      const scheme = pattern.slice(0, sep);
      const after  = pattern.slice(sep + 3);
      const slash  = after.indexOf('/');
      const host   = slash === -1 ? after : after.slice(0, slash);
      const path   = slash === -1 ? '' : after.slice(slash);
      if (scheme !== '*' && scheme !== u.protocol.replace(':', '')) return false;
      if (host !== '*') {
        if (host.startsWith('*.')) {
          const suffix = host.slice(2);
          if (u.hostname !== suffix && !u.hostname.endsWith('.' + suffix)) return false;
        } else if (u.hostname !== host) return false;
      }
      const rx = new RegExp(
        '^' + path.replace(/[.+^${}()|[\]\\]/g, '\\$&').replace(/\*/g, '.*') + '$'
      );
      return rx.test(u.pathname + u.search);
    } catch { return false; }
  }

  function matchesPage(script) {
    return script.matches.some(p => matchPattern(p, location.href));
  }

  // ── State ─────────────────────────────────────────────────────────────────

  function loadState() {
    try {
      const raw = GM_getValue(STATE_KEY, null);
      if (raw) return JSON.parse(raw);
    } catch { /* */ }
    const d = {};
    SCRIPTS.forEach(s => { d[s.id] = true; });
    return d;
  }

  function saveState(s) { GM_setValue(STATE_KEY, JSON.stringify(s)); }

  function loadHidden() {
    try {
      const raw = GM_getValue(HIDDEN_KEY, null);
      if (raw) return new Set(JSON.parse(raw));
    } catch { /* */ }
    return new Set();
  }

  function saveHidden(h) { GM_setValue(HIDDEN_KEY, JSON.stringify([...h])); }

  function loadDiscovered() {
    try {
      const raw = GM_getValue(DISCOVERED_KEY, null);
      if (raw) return JSON.parse(raw);
    } catch { /* */ }
    return [];
  }

  function saveDiscovered(list) { GM_setValue(DISCOVERED_KEY, JSON.stringify(list)); }

  // ── GitHub scan ─────────────────────────────────────────────────────────────

  function ghApi(path) {
    return new Promise((resolve, reject) => {
      GM_xmlhttpRequest({
        method:  'GET',
        url:     GH_API + path,
        headers: { 'Accept': 'application/vnd.github+json' },
        onload(res) {
          if (res.status === 403 && /rate limit/i.test(res.responseText || '')) {
            return reject(new Error('rate limit'));
          }
          if (res.status < 200 || res.status >= 300) return reject(new Error('HTTP ' + res.status));
          try { resolve(JSON.parse(res.responseText)); }
          catch (e) { reject(e); }
        },
        onerror: () => reject(new Error('network')),
      });
    });
  }

  function fetchRaw(url) {
    return new Promise((resolve, reject) => {
      GM_xmlhttpRequest({
        method: 'GET',
        url,
        onload: res => (res.status >= 200 && res.status < 300)
          ? resolve(res.responseText)
          : reject(new Error('HTTP ' + res.status)),
        onerror: () => reject(new Error('network')),
      });
    });
  }

  // Returns an array of discovered script entries (repos not already in BASE_SCRIPTS).
  async function scanGitHub(onProgress) {
    const repos = await ghApi(`/users/${GH_USER}/repos?per_page=100&sort=updated`);
    const known = new Set(BASE_SCRIPTS.map(s => repoFromUrl(s.url).toLowerCase()));
    const found = [];
    let i = 0;

    for (const repo of repos) {
      i++;
      if (onProgress) onProgress(i, repos.length);
      if (known.has(repo.name.toLowerCase())) continue;

      let tree;
      try {
        tree = await ghApi(`/repos/${GH_USER}/${repo.name}/git/trees/${repo.default_branch}?recursive=1`);
      } catch { continue; }

      const blobs = (tree.tree || []).filter(t => t.type === 'blob');
      const file  = blobs.find(f => /\.user\.js$/i.test(f.path)) ||
                    blobs.find(f => /\.js$/i.test(f.path));
      if (!file) continue;

      const rawUrl = `https://raw.githubusercontent.com/${GH_USER}/${repo.name}/${repo.default_branch}/` +
                     file.path.split('/').map(encodeURIComponent).join('/');

      let meta = { name: repo.name, match: ['*://*/*'] };
      try {
        const parsed = parseMeta(await fetchRaw(rawUrl));
        if (parsed.name)         meta.name  = parsed.name;
        if (parsed.match.length) meta.match = parsed.match;
      } catch { /* keep defaults */ }

      found.push({
        id:        'gh-' + repo.name.toLowerCase(),
        name:      meta.name,
        category:  guessCategory(repo.name + ' ' + meta.match.join(' ')),
        url:       rawUrl,
        matches:   meta.match,
        addedDate: new Date().toISOString().slice(0, 10),
        discovered: true,
      });
    }
    return found;
  }

  // ── Script execution ──────────────────────────────────────────────────────

  function stripHeader(src) {
    return src.replace(/\/\/ ==UserScript==[\s\S]*?\/\/ ==\/UserScript==/m, '').trim();
  }

  function execScript(script) {
    return new Promise((resolve, reject) => {
      GM_xmlhttpRequest({
        method:  'GET',
        url:     script.url,
        headers: { 'Cache-Control': 'max-age=300' },
        onload(res) {
          if (res.status < 200 || res.status >= 300) {
            console.warn(`[TM Manager] ${script.name}: HTTP ${res.status}`);
            return reject(new Error(`HTTP ${res.status}`));
          }
          try {
            // eslint-disable-next-line no-eval
            eval(stripHeader(res.responseText));
            resolve();
          } catch (e) {
            console.error(`[TM Manager] ${script.name} threw:`, e);
            reject(e);
          }
        },
        onerror(e) {
          console.warn(`[TM Manager] ${script.name}: network error`, e);
          reject(e);
        },
      });
    });
  }

