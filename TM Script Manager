  }
  document.addEventListener('mousedown', (e) => { if (pinned && !e.target.closest('nav') && !e.target.closest('.cpx-panel')) unpin(); }, true);
  new MutationObserver(() => {
    document.querySelectorAll('nav > div[title]').forEach((node) => {
      if (node.dataset.cpSection || !SECTION_TITLES.includes(node.getAttribute('title'))) return;
      node.dataset.cpSection = '1';
      node.addEventListener('click', (e) => { e.preventDefault(); pin(node); });
      node.addEventListener('mouseenter', () => { if (pinned && pinned !== node) pin(node); });
    });
  }).observe(document.documentElement, { childList: true, subtree: true });

  /* ============================== badge ================================ */
  onReady(() => { const b = el('div', null, 'CrazyParts UI \u2713'); b.id = 'cp-ui-badge'; document.body.appendChild(b); });
})();
