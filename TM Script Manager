// ==UserScript==
// @name         TM Script Manager
// @namespace    https://github.com/THVjQ
// @version      1.3.0
// @description  Loads and manages all custom scripts from GitHub with a floating toggle UI and API key storage
// @author       THVjQ
// @match        *://*/*
// @grant        GM_setValue
// @grant        GM_getValue
// @grant        GM_xmlhttpRequest
// @grant        GM_addValueChangeListener
// @grant        GM_openInTab
// @connect      raw.githubusercontent.com
// @run-at       document-idle
// ==/UserScript==

