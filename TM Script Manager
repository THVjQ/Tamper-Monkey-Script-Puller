  // ── Build UI ──────────────────────────────────────────────────────────────

  function buildUI(state, hidden) {
    if (document.getElementById('__tmm_root__')) return;

    const style = document.createElement('style');
    style.textContent = CSS;
    document.head.appendChild(style);

    const root = document.createElement('div');
    root.id = '__tmm_root__';
    Object.assign(root.style, {
      position: 'fixed', bottom: '120px', right: '0',
      zIndex: '2147483647', userSelect: 'none',
    });

    // Pull tab
    const tab = document.createElement('button');
    tab.id = '__tmm_tab__';
    tab.title = 'TM Script Manager';

    const tabIcon = document.createElement('span');
    tabIcon.id = '__tmm_tab__-icon';
    tabIcon.textContent = '⚡';

    const badge = document.createElement('span');
    badge.id = '__tmm_badge__';

    const newDot = document.createElement('span');
    newDot.id = '__tmm_new_dot__';

    tab.appendChild(newDot);
    tab.appendChild(tabIcon);
    tab.appendChild(badge);

    function refreshFab() {
      const n = SCRIPTS.filter(s => !hidden.has(s.id) && matchesPage(s) && state[s.id]).length;
      badge.textContent = n;
      badge.style.display = n > 0 ? 'block' : 'none';
      newDot.style.display = SCRIPTS.some(s => !hidden.has(s.id) && isNew(s)) ? 'block' : 'none';
    }

    // Panel
    const panel = document.createElement('div');
    panel.id = '__tmm_panel__';

    // Header
    const header = document.createElement('div');
    header.className = 'tmm-header';

    const titleEl = document.createElement('div');
    titleEl.className = 'tmm-title';
    titleEl.textContent = '⚡ TM Scripts';

    let editMode = false;

    // Scan button (GitHub auto-discovery)
    let scanning = false;
    const scanBtn = document.createElement('button');
    scanBtn.className = 'tmm-hbtn';
    scanBtn.textContent = '🔄 Scan';
    scanBtn.title = 'Scan GitHub for new scripts';
    scanBtn.onclick = async () => {
      if (scanning) return;
      scanning = true;
      scanBtn.className = 'tmm-hbtn busy';
      scanBtn.textContent = 'Scanning…';
      try {
        const found = await scanGitHub((i, total) => {
          scanBtn.textContent = `Scan ${i}/${total}`;
        });

        const existing = loadDiscovered();
        const byId = new Map(existing.map(s => [s.id, s]));
        const fresh = [];
        found.forEach(s => {
          if (!byId.has(s.id)) { byId.set(s.id, s); fresh.push(s); }
        });
        const merged = [...byId.values()];

        saveDiscovered(merged);
        SCRIPTS = BASE_SCRIPTS.concat(merged);

        // Newly found scripts default to enabled
        fresh.forEach(s => { if (!(s.id in state)) state[s.id] = true; });
        saveState(state);

        // Run any new ones that match the current page, no reload needed
        fresh.filter(s => state[s.id] && matchesPage(s)).forEach(execScript);

        renderSidebar();
        renderList(activeCat);
        refreshFab();
        updateCount();

        scanBtn.className = 'tmm-hbtn ok';
        scanBtn.textContent = fresh.length ? `✓ ${fresh.length} new` : '✓ Up to date';
      } catch (e) {
        scanBtn.className = 'tmm-hbtn err';
        scanBtn.textContent = e.message === 'rate limit' ? '⚠ Rate limit' : '⚠ Failed';
      } finally {
        scanning = false;
        setTimeout(() => {
          if (scanning) return;
          scanBtn.className = 'tmm-hbtn';
          scanBtn.textContent = '🔄 Scan';
        }, 2600);
      }
    };

    const editBtn = document.createElement('button');
    editBtn.className = 'tmm-hbtn';
    editBtn.textContent = 'Edit';

    const closeBtn = document.createElement('button');
    closeBtn.className = 'tmm-hbtn';
    closeBtn.textContent = '✕';
    closeBtn.onclick = () => { panel.style.display = 'none'; };

    header.appendChild(titleEl);
    header.appendChild(scanBtn);
    header.appendChild(editBtn);
    header.appendChild(closeBtn);
    panel.appendChild(header);

    // Body
    const body = document.createElement('div');
    body.className = 'tmm-body';

    const sidebar = document.createElement('div');
    sidebar.className = 'tmm-sidebar';

    const listArea = document.createElement('div');
    listArea.className = 'tmm-list';

    let activeCat = CATEGORIES[0];

    function visibleIn(cat) {
      return SCRIPTS.filter(s => s.category === cat && !hidden.has(s.id));
    }

    function renderList(cat) {
      listArea.innerHTML = '';
      const items = visibleIn(cat);

      if (!items.length) {
        const wrap = document.createElement('div');
        wrap.className = 'tmm-empty';
        wrap.innerHTML = `<div class="tmm-empty-icon">🗑️</div>
          <div class="tmm-empty-msg">All scripts in this category are hidden.</div>`;
        const restoreBtn = document.createElement('button');
        restoreBtn.className = 'tmm-restore';
        restoreBtn.textContent = 'Restore all hidden';
        restoreBtn.onclick = () => {
          SCRIPTS.filter(s => s.category === cat).forEach(s => hidden.delete(s.id));
          saveHidden(hidden);
          renderSidebar();
          renderList(activeCat);
          refreshFab();
        };
        wrap.appendChild(restoreBtn);
        listArea.appendChild(wrap);
        return;
      }

      items.forEach((script, idx) => {
        const onPage = matchesPage(script);

        const row = document.createElement('div');
        row.className = 'tmm-row' + (onPage ? '' : ' off');

        const dot = document.createElement('div');
        dot.className = 'tmm-dot';

        const name = document.createElement('div');
        name.className = 'tmm-name';
        name.textContent = script.name;
        name.title = onPage ? 'Active on this page' : 'Runs on other sites';

        row.appendChild(dot);
        row.appendChild(name);

        if (isNew(script)) {
          const nb = document.createElement('span');
          nb.className = 'tmm-new';
          nb.textContent = 'NEW';
          row.appendChild(nb);
        }

        // Toggle
        const lbl = document.createElement('label');
        lbl.className = 'tmm-toggle';
        const cb = document.createElement('input');
        cb.type = 'checkbox';
        cb.checked = !!state[script.id];
        const track = document.createElement('span');
        track.className = 'tmm-track';
        const knob = document.createElement('span');
        knob.className = 'tmm-knob';
        cb.addEventListener('change', () => {
          state[script.id] = cb.checked;
          saveState(state);
          row.classList.toggle('off', !cb.checked && !onPage);
          dot.style.background = (cb.checked && onPage) ? '#0ea5e9' : '#cbd5e1';
          refreshFab();
          updateCount();
        });
        lbl.appendChild(cb);
        lbl.appendChild(track);
        lbl.appendChild(knob);
        row.appendChild(lbl);

        // Delete / hide button
        const del = document.createElement('button');
        del.className = 'tmm-del';
        del.title = 'Hide this script';
        del.textContent = '✕';
        del.onclick = () => {
          hidden.add(script.id);
          saveHidden(hidden);
          renderSidebar();
          renderList(activeCat);
          refreshFab();
          updateCount();
        };
        row.appendChild(del);

        listArea.appendChild(row);
        if (idx < items.length - 1) {
          const sep = document.createElement('div');
          sep.className = 'tmm-sep';
          listArea.appendChild(sep);
        }
      });
    }

    function renderSidebar() {
      sidebar.innerHTML = '';
      CATEGORIES.forEach(cat => {
        const btn = document.createElement('button');
        btn.className = 'tmm-cat' + (cat === activeCat ? ' active' : '');

        const icon = document.createElement('div');
        icon.className = 'tmm-cat-icon';
        icon.textContent = CAT_ICONS[cat];

        const lbl = document.createElement('div');
        lbl.className = 'tmm-cat-lbl';
        lbl.textContent = cat;

        const cnt = document.createElement('div');
        cnt.className = 'tmm-cat-n';
        cnt.textContent = visibleIn(cat).length;

        btn.appendChild(icon);
        btn.appendChild(lbl);
        btn.appendChild(cnt);
        btn.onclick = () => {
          activeCat = cat;
          renderSidebar();
          renderList(cat);
        };
        sidebar.appendChild(btn);
      });
    }

    editBtn.onclick = () => {
      editMode = !editMode;
      editBtn.textContent = editMode ? 'Done' : 'Edit';
      editBtn.classList.toggle('danger', editMode);
      listArea.classList.toggle('edit-on', editMode);
    };

    renderSidebar();
    renderList(activeCat);

    body.appendChild(sidebar);
    body.appendChild(listArea);
    panel.appendChild(body);

    // Footer
    const footer = document.createElement('div');
    footer.className = 'tmm-footer';

    const copyBtn = document.createElement('button');
    copyBtn.className = 'tmm-copy';
    copyBtn.innerHTML = '📋 Copy TM Snippet';
    copyBtn.title = 'Copy boilerplate for a new Tampermonkey script';
    copyBtn.onclick = () => {
      const snippet =
`// ==UserScript==
// @name         New Script Name
// @namespace    https://github.com/THVjQ
// @version      1.0.0
// @description  What this script does
// @author       THVjQ
// @match        *://*/*
// @grant        GM_setValue
// @grant        GM_getValue
// @grant        GM_xmlhttpRequest
// @connect      raw.githubusercontent.com
// @run-at       document-idle
// ==/UserScript==

(function() {
  'use strict';
  // Your code here
  // Tip: push it to a repo under github.com/THVjQ, then hit Scan in TM Script Manager
})();`;
      navigator.clipboard.writeText(snippet).then(() => {
        copyBtn.textContent = '✓ Copied!';
        copyBtn.classList.add('ok');
        setTimeout(() => {
          copyBtn.innerHTML = '📋 Copy TM Snippet';
          copyBtn.classList.remove('ok');
        }, 2200);
      }).catch(() => {
        copyBtn.textContent = 'Allow clipboard access';
        setTimeout(() => { copyBtn.innerHTML = '📋 Copy TM Snippet'; }, 2200);
      });
    };

    const countEl = document.createElement('div');
    countEl.className = 'tmm-pgcount';

    function updateCount() {
      const n = SCRIPTS.filter(s => !hidden.has(s.id) && state[s.id] && matchesPage(s)).length;
      countEl.textContent = `${n} active here`;
    }
    updateCount();

    footer.appendChild(copyBtn);
    footer.appendChild(countEl);
    panel.appendChild(footer);

    // Toggle panel
    tab.addEventListener('click', e => {
      e.stopPropagation();
      const open = panel.style.display === 'block';
      panel.style.display = open ? 'none' : 'block';
      if (!open) {
        renderSidebar();
        renderList(activeCat);
        updateCount();
      }
    });

    document.addEventListener('click', e => {
      if (!root.contains(e.target)) panel.style.display = 'none';
    }, true);

    root.appendChild(panel);
    root.appendChild(tab);
    document.body.appendChild(root);

    refreshFab();
  }

  // ── Bootstrap ─────────────────────────────────────────────────────────────

  async function main() {
    const discovered = loadDiscovered();
    SCRIPTS = BASE_SCRIPTS.concat(discovered);

    const state  = loadState();
    const hidden = loadHidden();
    SCRIPTS.forEach(s => { if (!(s.id in state)) state[s.id] = true; });
    saveState(state);

    const toLoad = SCRIPTS.filter(s => !hidden.has(s.id) && state[s.id] && matchesPage(s));
    await Promise.allSettled(toLoad.map(execScript));

    if (document.body) {
      buildUI(state, hidden);
    } else {
      document.addEventListener('DOMContentLoaded', () => buildUI(state, hidden));
    }
  }

  main();

})();
