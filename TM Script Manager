  const CPX_FILTER_KEY = 'cpxFilterPref';
  function getFilterPref() {
    try { return localStorage.getItem(CPX_FILTER_KEY) === 'accessories' ? 'accessories' : 'repair'; }
    catch (e) { return 'repair'; }
  }
