    {
      id:   'sos-pos-enlarge',
      name: 'Enlarge',
      group: 'SOS POS',
      url:  `${GH}/sos-pos-enlarge/main/sos-pos-enlarge.user.js`,
      matches: ['*://app.sospos.com.au/*'],
    },
    {
      id:   'sos-pos-bulk-uploader',
      name: 'Bulk Uploader',
      group: 'SOS POS',
      url:  `${GH}/sos-pos-bulk-uploader/main/sos-pos-bulk-uploader.user.js`,
      matches: ['https://app.sospos.com.au/*'],
    },
    {
      id:       'sos-pos-google-review-timer',
      name:     'Google Review Timer',
      group:    'SOS POS',
