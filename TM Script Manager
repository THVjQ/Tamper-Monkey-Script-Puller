  // ── URL pattern matching ──────────────────────────────────────────────────

  function matchPattern(pattern, url) {
    try {
      const u = new URL(url);
      const sep = pattern.indexOf('://');
      if (sep === -1) return false;
      const scheme = pattern.slice(0, sep);
      const after  = pattern.slice(sep + 3);
      const slash  = after.indexOf('/');
      const host   = slash === -1 ? after : after.slice(0, slash);
      const path   = slash === -1 ? '' : after.slice(slash);
      if (scheme !== '*' && scheme !== u.protocol.replace(':', '')) return false;
      if (host !== '*') {
        if (host.startsWith('*.')) {
          const suffix = host.slice(2);
          if (u.hostname !== suffix && !u.hostname.endsWith('.' + suffix)) return false;
        } else if (u.hostname !== host) return false;
      }
      const rx = new RegExp(
        '^' + path.replace(/[.+^${}()|[\]\\]/g, '\\$&').replace(/\*/g, '.*') + '$'
      );
      return rx.test(u.pathname + u.search);
    } catch { return false; }
  }

  function matchesPage(script) {
    return script.matches.some(p => matchPattern(p, location.href));
  }

  // ── State ─────────────────────────────────────────────────────────────────

  function loadState() {
    try {
      const raw = GM_getValue(STATE_KEY, null);
      if (raw) return JSON.parse(raw);
    } catch { /* fall through */ }
    const defaults = {};
    SCRIPTS.forEach(s => { defaults[s.id] = true; });
    return defaults;
  }

  function saveState(state) {
    GM_setValue(STATE_KEY, JSON.stringify(state));
  }

  // ── Script execution ──────────────────────────────────────────────────────

  function stripHeader(src) {
    return src.replace(/\/\/ ==UserScript==[\s\S]*?\/\/ ==\/UserScript==/m, '').trim();
  }

  function execScript(script) {
    return new Promise((resolve, reject) => {
      GM_xmlhttpRequest({
        method:  'GET',
        url:     script.url,
        headers: { 'Cache-Control': 'max-age=300' },
        onload(res) {
          if (res.status < 200 || res.status >= 300) {
            console.warn(`[TM Manager] ${script.name}: HTTP ${res.status}`);
            return reject(new Error(`HTTP ${res.status}`));
          }
          try {
            // eslint-disable-next-line no-eval
            eval(stripHeader(res.responseText));
            resolve();
          } catch (e) {
            console.error(`[TM Manager] ${script.name} threw:`, e);
            reject(e);
          }
        },
        onerror(e) {
          console.warn(`[TM Manager] ${script.name}: network error`, e);
          reject(e);
        },
      });
    });
  }

  // ── Scan: updates + newly-published scripts ───────────────────────────────

  function fetchText(url) {
    return new Promise((resolve, reject) => {
      GM_xmlhttpRequest({
        method: 'GET', url,
        headers: { 'Cache-Control': 'no-cache' },
        onload(res) {
          if (res.status >= 200 && res.status < 300) resolve(res.responseText);
          else reject(new Error(`HTTP ${res.status}`));
        },
        onerror() { reject(new Error('network error')); },
      });
    });
  }

  function fetchJSON(url) {
    return new Promise((resolve, reject) => {
      GM_xmlhttpRequest({
        method: 'GET', url,
        headers: { 'Accept': 'application/vnd.github+json' },
        onload(res) {
          if (res.status < 200 || res.status >= 300) {
            return reject(new Error(res.status === 403
              ? 'GitHub rate limit — try again later'
              : `HTTP ${res.status}`));
          }
          try { resolve(JSON.parse(res.responseText)); }
          catch (e) { reject(e); }
        },
        onerror() { reject(new Error('network error')); },
      });
    });
  }

  function parseVersion(src) {
    const m = src.match(/@version\s+(\S+)/);
    return m ? m[1] : null;
  }

  // Repo names already tracked, derived from each script's raw URL
  function knownRepoSet() {
    const set = new Set();
    SCRIPTS.forEach(s => {
      const repo = s.url.slice(GH.length + 1).split('/')[0];
      if (repo) set.add(repo.toLowerCase());
    });
    return set;
  }

  function loadVersions() {
    try { return JSON.parse(GM_getValue(VERSIONS_KEY, '{}')); }
    catch { return {}; }
  }

  // Fetch each tracked script, compare @version to last scan → list changed ones.
  // First scan just records a baseline and reports nothing as updated.
  async function scanUpdates() {
    const stored  = loadVersions();
    const first   = Object.keys(stored).length === 0;
    const updates = [];
    await Promise.all(SCRIPTS.map(async s => {
      try {
        const ver  = parseVersion(await fetchText(s.url)) || '?';
        const prev = stored[s.id];
        if (!first && prev && prev !== ver) {
          updates.push({ name: s.name, from: prev, to: ver });
        }
        stored[s.id] = ver;
      } catch { /* skip unreachable script */ }
    }));
    GM_setValue(VERSIONS_KEY, JSON.stringify(stored));
    return updates;
  }

  // List org repos, keep ones not already tracked that contain a *.user.js file.
  async function scanNew() {
    const known = knownRepoSet();
    const repos = await fetchJSON(
      `https://api.github.com/users/${ORG}/repos?per_page=100&sort=updated`);
    const candidates = repos.filter(r =>
      !r.fork && !r.archived && !known.has(r.name.toLowerCase()));
    const found = [];
    await Promise.all(candidates.map(async r => {
      try {
        const tree = await fetchJSON(
          `https://api.github.com/repos/${ORG}/${r.name}/git/trees/${r.default_branch}?recursive=1`);
        const uj = (tree.tree || []).find(t => /\.user\.js$/i.test(t.path));
        if (uj) found.push({ repo: r.name, url: r.html_url });
      } catch { /* skip repo we can't read */ }
    }));
    return found;
  }

