      group: 'CrazyParts',
      url:  `${GH}/crazyparts-mix-cart-addon/main/crazyparts-mix-cart-addon.user.js`,
      matches: ['*://www.crazyparts.com.au/*'],
    },
    // ── SOS POS ───────────────────────────────────────────────────────────────
    {
