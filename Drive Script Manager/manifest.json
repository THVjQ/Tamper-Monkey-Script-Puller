{
  "manifest_version": 3,
  "name": "Drive Script Manager",
  "version": "1.0",
  "description": "Fetch and toggle your userscripts straight from Google Drive",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://drive.google.com/*",
    "https://*.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Drive Script Manager"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
